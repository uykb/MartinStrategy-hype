# Hyperliquid 马丁格尔策略机器人 — 环境变量配置
# cp .env.example .env 然后填入密钥
#
# 部署流程：
#   1. 上传 bot 二进制 + .env 到服务器同一目录
#   2. cp .env.example .env 并填入密钥
#   3. ./bot 即可运行

# ★★★ 必填 ★★★
MARTIN_EXCHANGE_API_KEY=
MARTIN_EXCHANGE_API_SECRET=

# ★★★ 可选（以下为默认值）★★★
MARTIN_EXCHANGE_SYMBOL=HYPE
MARTIN_EXCHANGE_USE_TESTNET=false
MARTIN_STRATEGY_MAX_SAFETY_ORDERS=9
MARTIN_STRATEGY_ATR_PERIOD=14
MARTIN_STRATEGY_BASE_RATIO=0.05
MARTIN_STORAGE_SQLITE_PATH=data/bot.db
MARTIN_STORAGE_REDIS_ADDR=
MARTIN_LOG_LEVEL=info
MARTIN_HEALTH_ADDR=:8080
