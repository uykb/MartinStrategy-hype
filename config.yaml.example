# Hyperliquid 马丁格尔策略机器人 — YAML 配置文件
# ⚠️ 复制此文件为 config.yaml 并填入真实密钥
# ⚠️ config.yaml 已加入 .gitignore，不会被提交到仓库
#
# Docker 部署方式：
#   将 config.yaml 放在 docker-compose.yml 同目录下，容器会自动通过 volume 挂载读取
#   不需要设置 MARTIN_EXCHANGE_API_KEY 环境变量

exchange:
  api_key: ""            # ★ 必填：Agent 钱包私钥（64 位十六进制，不含 0x 前缀）
  api_secret: ""         # ★ 必填：主钱包地址（42 位十六进制，含 0x 前缀）
  symbol: "HYPE"         # 交易对
  use_testnet: false     # 是否使用测试网

strategy:
  max_safety_orders: 9   # 网格层数（9级：1h/2h/4h/8h/12h/1d/3d/1w/1M）
  atr_period: 14         # ATR 计算周期
  base_ratio: 0.05       # 头仓金额 = 余额 × base_ratio

storage:
  sqlite_path: "/app/data/bot.db"  # Docker 中持久化到 /app/data
  redis_addr: ""          # 留空 = 不启用 Redis（单实例部署无需 Redis）
  redis_pass: ""
  redis_db: 0

log:
  level: "info"

health:
  addr: ":8080"
